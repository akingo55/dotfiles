{
  "permissions": {
    "allow": [
      "Read(~/.zshrc)",
      "Read(~/.claude/**)",
      "Read(~/repo/**)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.ssh/**)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/config/database.yml)",
      "Read(**/config/credentials.json)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "editorMode": "vim"
}
